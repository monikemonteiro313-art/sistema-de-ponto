rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /pontos/{userId} {
      allow read, write: if true;
    }
    match /config/{configId} {
      allow read, write: if true;
    }
    match /auditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
